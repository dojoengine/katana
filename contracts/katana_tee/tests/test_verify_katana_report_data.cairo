//! Unit tests for verify_katana_report_data function.
//!
//! These test vectors were generated by:
//! cargo test -p katana_tee_client --test generate_report_data_vectors -- --nocapture

use core::integer::u512;
use katana_tee::katana_report_utils::verify_katana_report_data;

/// Test case 1: Large values
/// state_root: 0x0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef
/// block_hash: 0x00fedcba9876543210fedcba9876543210fedcba9876543210fedcba98765432
/// commitment (poseidon_hash): 0x0707ec0977a29e3a54c6032ec5514d6188d75930d6d6eeb096cf4ca323df4aac
#[test]
fn test_verify_katana_report_data_case_1() {
    let report_data = u512 {
        limb0: 0x614d51c52e03c6543a9ea27709ec0707,
        limb1: 0xac4adf23a34ccf96b0eed6d63059d788,
        limb2: 0,
        limb3: 0,
    };

    let state_root: felt252 = 0x0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef;
    let block_hash: felt252 = 0x00fedcba9876543210fedcba9876543210fedcba9876543210fedcba98765432;

    let result = verify_katana_report_data(report_data, state_root, block_hash);
    assert(result, 'Verification should pass');
}

