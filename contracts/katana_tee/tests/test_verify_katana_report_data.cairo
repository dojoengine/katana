/// Test case 3: Realistic block data
/// state_root: 0x04b1a39276c1df7ca78febcb6850f3649e826a3f6618e6ab30b48dcc948de1ad
/// block_hash: 0x06c5e8a47fb34d21c08e4eb6a91fa7bce3f2d5a490c8b7e1d26f43098a5bc7e2
/// commitment (poseidon_hash): 0x060b6465a73cb1456f7fadb742744d61321a68a24f6f1a36803fdf4e922719a3
#[test]
fn test_verify_katana_report_data_case_3() {
    let report_data = u512 {
        limb0: 0x614d7442b7ad7f6f45b13ca765640b06,
        limb1: 0xa31927924edf3f80361a6f4fa2681a32,
        limb2: 0,
        limb3: 0,
    };

    let state_root: felt252 = 0x04b1a39276c1df7ca78febcb6850f3649e826a3f6618e6ab30b48dcc948de1ad;
    let block_hash: felt252 = 0x06c5e8a47fb34d21c08e4eb6a91fa7bce3f2d5a490c8b7e1d26f43098a5bc7e2;

