/// Test case 4: Commitment mismatch (should panic)
/// Uses wrong state_root for the report_data
#[test]
#[should_panic(expected: 'Commitment mismatch')]
fn test_verify_katana_report_data_mismatch() {
    // report_data was computed with state_root=0x1, block_hash=0x2
    let report_data = u512 {
        limb0: 0x452f807b1f0771cce0b2b2ec3d4ad405,
        limb1: 0x1a89f9704f51466c31c70f4f062d79dd,
        limb2: 0,
        limb3: 0,
    };

    // But we pass different state_root (0x3 instead of 0x1)
    let state_root: felt252 = 0x3;
    let block_hash: felt252 = 0x2;

    // This should panic with 'Commitment mismatch'
    verify_katana_report_data(report_data, state_root, block_hash);
}

/// Test that limb2 must be zero
#[test]
#[should_panic(expected: 'Report data limb2 must be 0')]
fn test_verify_katana_report_data_limb2_nonzero() {
    let report_data = u512 { limb0: 0, limb1: 0, limb2: 1, limb3: 0, };

    let state_root: felt252 = 0x123;
    let block_hash: felt252 = 0x456;

    verify_katana_report_data(report_data, state_root, block_hash);
}

/// Test that limb3 must be zero
#[test]
#[should_panic(expected: 'Report data limb3 must be 0')]
fn test_verify_katana_report_data_limb3_nonzero() {
    let report_data = u512 { limb0: 0, limb1: 0, limb2: 0, limb3: 1, };

    let state_root: felt252 = 0x123;
