target
.snfoundry_cache/
snfoundry_trace/
coverage/
profile/
.env
docs/starknet-foundry-docs/
docs/plans/

# Claude agent (internal tooling, not for delivery)
.claude/

# Git worktrees
.worktrees/

# Nested sub-workspace lockfiles (amd-sev-snp-attestation-sdk, starknet-rust,
# etc.) stay ignored — they regenerate during builds and aren't load-bearing.
**/Cargo.lock
# Track the top-level client workspace lockfile for reproducible builds against
# katana root's rustc 1.89.0 (some upstream transitive deps have since bumped
# their MSRV past 1.89; the lockfile pins MSRV-compat versions).
!/Cargo.lock

artifacts/
.tee_deployment_state.json

# Generated Cairo test fixtures (regenerate with: katana-tee generate-cairo-fixtures)
# Uncomment to track fixtures in git:
# !contracts/amd_tee_registry/tests/test_journal_decode_from_fixtures/test_journal_decode_fixtures.cairo
