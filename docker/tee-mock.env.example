# Settings for the Katana + saya-tee mock-prove dev stack.
# Copy to a local `.env` in the directory you run `docker compose` from, then edit.

# -----------------------------------------------------------------------------
# REQUIRED: the L2 settlement layer you want piltover deployed to.
# -----------------------------------------------------------------------------
#
# You have two easy options:
#
# A) Local `katana --dev` as L2 (fastest, zero external accounts):
#      # In a separate terminal:
#      katana --dev --http.addr 0.0.0.0 --http.port 5051
#      # Copy a prefunded dev account address + private key from its startup output.
#    Then set:
#      SETTLEMENT_RPC_URL=http://host.docker.internal:5051
#      SETTLEMENT_ACCOUNT_ADDRESS=<one of the printed dev accounts>
#      SETTLEMENT_ACCOUNT_PRIVATE_KEY=<matching private key>
#      SETTLEMENT_CHAIN_ID=SN_SEPOLIA   # katana --dev defaults to this
#
# B) Sepolia public RPC (realistic, but needs a funded STRK account):
#      SETTLEMENT_RPC_URL=https://starknet-sepolia.public.blastapi.io/rpc/v0_9
#      SETTLEMENT_ACCOUNT_ADDRESS=0x...           # https://starknet-faucet.vercel.app/
#      SETTLEMENT_ACCOUNT_PRIVATE_KEY=0x...
#      SETTLEMENT_CHAIN_ID=sepolia

SETTLEMENT_RPC_URL=http://host.docker.internal:5051
SETTLEMENT_ACCOUNT_ADDRESS=0x...
SETTLEMENT_ACCOUNT_PRIVATE_KEY=0x...
SETTLEMENT_CHAIN_ID=SN_SEPOLIA

# -----------------------------------------------------------------------------
# OPTIONAL: defaults work for most users.
# -----------------------------------------------------------------------------

# L3 rollup chain id. Shows up in tx signatures, so only change across a fresh deploy.
CHAIN_ID=katana_tee_mock

# L3 block time in milliseconds.
BLOCK_TIME=3000

# Deterministic salts for piltover + tee-registry deploys. Changing these
# produces different contract addresses — useful if you've already deployed
# with the defaults on the same L2 account and want a fresh slate.
TEE_REGISTRY_SALT=0x7ee
PILTOVER_SALT=0x9117f0

# saya-tee flushes proofs every N L3 blocks. 1 = flush every block (lowest
# settlement latency, most L2 txs). Bump for batched settlement.
BATCH_SIZE=1

# Log filters.
SAYA_OPS_LOG=info
SAYA_TEE_LOG=info,persistent_tee=debug
