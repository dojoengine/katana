# cross-chain-dungeon settles to REAL Starknet Sepolia. Copy to `.env` and fill in.
# `.env` is gitignored — never commit real keys.

# --- Settlement layer: Starknet Sepolia ---
# A Sepolia RPC endpoint (v0.8/0.9). E.g. a provider URL or your own node.
SEPOLIA_RPC_URL="https://api.cartridge.gg/x/starknet/sepolia/rpc/v0_9"

# Operator account: deploys piltover (via init rollup), the mock TEE registry,
# the GAME_TOKEN/TokenSale/Entry contracts, and migrates the score world. Must be
# a deployed, STRK-funded Sepolia account (these are real, gas-costing txns).
OPERATOR_ADDRESS=""
OPERATOR_PRIVATE_KEY=""

# saya's settlement account: submits update_state to piltover on every settled
# batch (recurring real gas). MUST be a DIFFERENT funded account than the operator
# to avoid nonce contention (the first example hit exactly this). init rollup and
# saya-tee both use this account (the piltover operator is the only update_state caller).
SAYA_ADDRESS=""
SAYA_PRIVATE_KEY=""

# --- External dependency: USDC on Starknet Sepolia ---
# The real Circle USDC test token. VERIFY this address before use (and that it has
# 6 decimals). Players buy GAME_TOKEN with it; the dev-mint faucet bypasses it.
USDC_ADDRESS=""

# --- Economy (base units; GAME_TOKEN has 18 decimals, USDC has 6) ---
# 1 USDC (1e6 base) -> 100 GAME (100e18 base): rate = 100e18 / 1e6 = 1e14.
GAME_RATE="100000000000000"
# Entry fee: 50 GAME.
ENTRY_FEE="50000000000000000000"
# Reward per score point: 0.1 GAME.
REWARD_PER_POINT="100000000000000000"
