# =============================================================================
# Starknet Deployment Configuration
# =============================================================================

# Network Selection: devnet | sepolia | mainnet
STARKNET_NETWORK=devnet

# RPC URLs (use $STARKNET_RPC_URL in snfoundry.toml)
STARKNET_RPC_URL_DEVNET=http://127.0.0.1:5050
STARKNET_RPC_URL_SEPOLIA=https://starknet-sepolia.public.blastapi.io/rpc/v0_7
STARKNET_RPC_URL_MAINNET=https://starknet-mainnet.public.blastapi.io/rpc/v0_7

# Account Configuration
# For devnet: use "devnet-1" through "devnet-10" (predeployed, no setup needed)
# For sepolia/mainnet: use account name from accounts-file
STARKNET_ACCOUNT=devnet-1

# Only needed for sepolia/mainnet (devnet accounts are built-in)
STARKNET_ACCOUNTS_FILE=~/.starknet_accounts/starknet_open_zeppelin_accounts.json
STARKNET_KEYSTORE=
STARKNET_PRIVATE_KEY=

# Deployment Options
STARKNET_MAX_FEE=0
STARKNET_SALT=0x0
STARKNET_UNIQUE=false

# Devnet Configuration (optional, for starting devnet)
DEVNET_SEED=42
DEVNET_PORT=5050
DEVNET_ACCOUNTS=10

# snforge configuration (Scarb.toml uses env vars)
SNFORGE_EXIT_FIRST=false
SNFORGE_FUZZER_RUNS=256
SNFORGE_FUZZER_SEED=1234

# Contract Constructor Args (optional examples)
# Comma-separated values. Use empty for none.
AMD_TRUSTED_CERTS=
AMD_PROCESSOR_MODELS=
AMD_ROOT_CERTS=
