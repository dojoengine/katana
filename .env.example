# Katana TEE endpoint (for live E2E tests)
KATANA_RPC_URL=http://185.26.9.157:5050

# Starknet accounts
STARKNET_ACCOUNT=devnet-1
STARKNET_ACCOUNTS_FILE=~/.starknet_accounts/starknet_open_zeppelin_accounts.json

# RPC URLs
STARKNET_RPC_URL_DEVNET=http://127.0.0.1:5050
STARKNET_RPC_URL_SEPOLIA=

# Mainnet RPC for forking (Garaga verifier is deployed here)
# Note: starknet-devnet 0.7.x requires RPC v0.10 endpoints
MAINNET_RPC_URL=https://starknet-mainnet.public.blastapi.io/rpc/v0_10

# Devnet configuration
DEVNET_SEED=0
DEVNET_PORT=5050

# SP1 Prover Network (for live E2E tests)
SP1_PROVER=network
NETWORK_ADDRESS=
NETWORK_PRIVATE_KEY=
SP1_PRIVATE_KEY=

# Katana TEE Connection Settings
TEE_HOST=
TEE_SSH_PORT=
TEE_SSH_USER=
TEE_SSH_KEY=
VM_SSH_PORT=
VM_SSH_PASSWORD=
RPC_PORT=
