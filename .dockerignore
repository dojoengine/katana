.github/
!.github/Dockerfile*

# Python and other dev tools
.python-version
__pycache__/
*.pyc

# Rust development
rust-toolchain.toml
clippy.toml
rustfmt.toml
taplo.toml

# Node.js dependencies
**/node_modules/

# Test fixtures (ignore all except .tar.gz files)
tests/fixtures/*
!tests/fixtures/*.tar.gz

# Other
.config/
scripts/
Makefile
